# ImageKit API credentials (get from https://imagekit.io/)
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_URL=https://ik.imagekit.io/your_imagekit_id
SECRET=replace_with_a_long_random_secret

# Database connection
# Local Docker PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fastapi_db
# Neon / Heroku production example:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/fastapi_db

# Optional SQLAlchemy query logging
SQL_ECHO=false

# PostgreSQL environment variables (for Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=fastapi_db